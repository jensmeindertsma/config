{
  "layer": "top",
  "position": "top",

  "modules-left": ["hyprland/workspaces", "custom/arrow10"],

  "modules-right": [
    "custom/arrow9",
    "pulseaudio",
    "custom/arrow8",
    "network",
    "custom/arrow7",
    "memory",
    "custom/arrow6",
    "cpu",
    "custom/arrow5",
    "temperature",
    "custom/arrow4",
    "battery",
    "custom/arrow2",
    "clock#date",
    "custom/arrow1",
    "clock#time"
  ],

  // Modules

  "battery": {
    "interval": 10,
    "format-time": "{H}h {M:02}m",
    "format": "{icon} {capacity}% ",
    "format-charging": "пғ§ {capacity}%",
    "format-charging-full": "пғ§ {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-icons": ["пү„ ", "пүғ ", "пүӮ ", "пүҒ ", "пүҖ "],
    "tooltip": true,
    "tooltip-format": "{time} left, drawing {power}W"
  },

  "clock#time": {
    "interval": 1,
    "format": "{:%H:%M:%S}",
    "tooltip": false
  },

  "clock#date": {
    "interval": 20,
    "format": "{:%e %b %Y}",
    "tooltip": false
    //"tooltip-format": "{:%e %B %Y}"
  },

  "cpu": {
    "interval": 2,
    "tooltip": false,
    "format": "пӢӣ  {usage}%"
  },

  "memory": {
    "interval": 2,
    "format": "оҝ…  {percentage}%",
    "tooltip": false
  },

  "network": {
    "interval": 5,
    "format-wifi": "пҮ«  {essid} ({signalStrength}%) ({ipaddr}/{cidr})",
    "format-ethernet": "уұҳ– {ifname} ({ipaddr}/{cidr})",
    "format-disconnected": "no connection",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "disable-scroll-wraparound": true,
    "smooth-scrolling-threshold": 4,
    "enable-bar-scroll": true,
    "format": "{name}"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon}пҠ” {volume}%",
    "format-muted": "пҖҰ ",
    "format-icons": ["пҖ§ ", "пҖЁ "],
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "tooltip": false
  },

  // TODO: add microphone block

  "temperature": {
    "interval": 5,
    "format": "{icon} {temperatureC}В°",
    "format-icons": ["пӢӢ", "пӢҠ", "пӢү", "пӢҲ", "пӢҮ"],
    "tooltip": false
  },

  "custom/arrow1": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow2": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow3": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow4": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow5": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow6": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow7": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow8": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow9": {
    "format": "оӮІ",
    "tooltip": false
  },

  "custom/arrow10": {
    "format": "оӮ°",
    "tooltip": false
  }
}
