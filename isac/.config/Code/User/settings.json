{
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.codeLens": false,
  "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.fontSize": 18,
  "editor.formatOnSave": true,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",
  "window.autoDetectColorScheme": true,
  "window.customTitleBarVisibility": "windowed",
  "workbench.preferredDarkColorTheme": "One Dark Pro Darker",
  "workbench.preferredLightColorTheme": "Atom One Light",
  "workbench.startupEditor": "none",
  "direnv.restart.automatic": true,
  "editor.minimap.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",
  "git.openRepositoryInParentFolders": "never",
  "git.suggestSmartCommit": false,
  "C_Cpp.copilotHover": "disabled",
  "github.copilot.chat.agent.autoFix": false,
  "github.copilot.chat.agent.runTasks": false,
  "github.copilot.chat.codeGeneration.useInstructionFiles": false,
  "github.copilot.chat.useProjectTemplates": false,
  "github.copilot.editor.enableCodeActions": false,
  "github.copilot.renameSuggestions.triggerAutomatically": false,
  "github.copilot.chat.reviewSelection.enabled": false,
  "github.copilot.chat.copilotDebugCommand.enabled": false,
  "typescript.suggest.objectLiteralMethodSnippets.enabled": false,
  "accessibility.verbosity.inlineCompletions": false,
  "javascript.suggest.includeAutomaticOptionalChainCompletions": false,
  "typescript.suggest.includeAutomaticOptionalChainCompletions": false,
  "typescript.suggest.includeCompletionsForImportStatements": false
}
